# Database Configuration
NEON_POSTGRES_URI=postgresql://neondb_user:neoding=require
DB_TYPE=postgresdb
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=postgres
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres

# SMTP Configuration
SMTP_USER=smtp-user-here
SMTP_PASSWORD=smtp-password-here
ALERT_TO=alert-to-here
RESEND_API_KEY=re_xxxxxxxxx
RESEND_BASE_URL=https://api.resend.com/emails

# SFTP Configuration pour ingestion des valeurs réelles
SFTP_ENABLED=false
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=sftp_user
SFTP_SSH_PRIVATE_KEY_CONTENT=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
SFTP_PASSPHRASE=your-passphrase-here
SFTP_TIMEOUT=30
SFTP_REMOTE_DIRECTORY=/data/incoming
SFTP_ARCHIVE_DIRECTORY=/data/archived
SFTP_FILE_PATTERN=*.csv
SFTP_TEMP_LOCAL_DIR=/tmp/sftp_temp

# Domain-specific configurations
PREDICTIONS_POSTGRES_URI=postgresql://neondb_user:neondb_password@neondb_host:5432/predictions?sslmode=require&channel_binding=require