[flake8]
# Maximum line length
max-line-length = 120

# Exclude directories
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    .tox,
    notebooks,
    data,
    Services/_disabled,
    pipelines/_disabled,
    scripts/_disabled,
    src/ml/workflows/_disabled,
    tests/_disabled

# Ignore specific warnings
# W291: trailing whitespace
# W292: no newline at end of file
# W293: blank line contains whitespace
# W391: blank line at end of file
# W503: line break before binary operator (conflicts with W504)
# W504: line break after binary operator
# E401: multiple imports on one line
# E402: module level import not at top of file (common in notebooks/tests)
# E501: line too long (handled by max-line-length)
ignore = 
    W291,
    W292,
    W293,
    W391,
    W503,
    W504,
    E401,
    E402,
    E501

# Per-file ignores
# Tests often have imports not at top and other style issues
per-file-ignores =
    tests/*:E302,E303,E305,F401,F541,F841
    notebooks/*:E402,F401
    src/ml/connectors/*:F401
    src/ml/utils/monitoring/*:F401,F811
