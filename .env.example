# ============================================================================
# Infrastructure Dashboard Configuration
# Copy this file to .env and fill in your own values
# .env is gitignored and should NOT be committed to the repository
# ============================================================================

# ============================================================================
# Project & Environment Configuration
# ============================================================================

# Project name (used for HuggingFace Spaces and service URLs)
ProjectName=my-project

# Environment (Dev, Test, Prod)
Environment=Dev

# ============================================================================
# Services Configuration
# ============================================================================

# Comma-separated list of service/space names
# These will be created as HuggingFace Spaces
# Examples: Airflow, MLflow, JupyterLab
ServicesNames=Airflow,MLflow,JupyterLab,Streamlit,n8n,Gradio,EvidentlyAI,ClickHouse

# ============================================================================
# External Resources
# ============================================================================
ExternalServicesNames=GitHub,Supabase,Prefect,Neon

# ============================================================================
# APIs
# ============================================================================
APIsNames=Enedis,Vacances,Météo,Localisation
